# ==============================
# AI Model API Key
# ==============================
VITE_API_KEY=your_api_key_here


# ==============================
# Render Performance
# ==============================
VITE_RENDER_ANTIALIAS=true
VITE_RENDER_ALPHA=true
VITE_RENDER_SHADOWS=true
VITE_RENDER_POWER_PREFERENCE=high-performance
VITE_RENDER_PIXEL_RATIO_CAP=10


# ==============================
# Telegram Bot Bridge
# ==============================
VITE_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_RELAY_BASE_URL=/api/telegram
VITE_TELEGRAM_CHAT_ID=your_chat_id_here
VITE_TELEGRAM_SEND_VIDEO=true
VITE_TELEGRAM_SEND_IMAGE=true
VITE_TELEGRAM_SEND_LOGS=true
VITE_TELEGRAM_CONTINUOUS_VISION_FORWARDING=true
VITE_TELEGRAM_VISION_CLIP_SECONDS=30
VITE_TELEGRAM_VISION_INTERVAL_SECONDS=30
VITE_TELEGRAM_LOG_TIMEZONE=Asia/Tashkent


# ==============================
# Web App Gate
# ==============================
WEB_APP=true
web_app=true
VITE_WEB_APP=true


# ==============================
# Database
# ==============================
DATABASE_URL=postgresql://username:password@host:port/database
AUTH_SECRET=your_auth_secret_here